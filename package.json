{
  "name": "bluedoor-desktop",
  "version": "0.1.6",
  "description": "bluedoor — AI-powered investment research",
  "author": "bluedoor <sam@actionbase.co>",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "start": "electron .",
    "dist:mac": "electron-builder --config electron-builder.config.js --mac",
    "dist:win": "electron-builder --config electron-builder.config.js --win",
    "publish:mac": "electron-builder --config electron-builder.config.js --mac -p always",
    "publish:win": "electron-builder --config electron-builder.config.js --win -p always",
    "publish:all": "electron-builder --config electron-builder.config.js -mw -p always"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bluedoor": "^0.2.7",
    "electron-updater": "^6.3.0",
    "node-pty": "^1.1.0",
    "tar": "^7.5.13"
  }
}
